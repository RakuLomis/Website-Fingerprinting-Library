    "epochs": 30,
    "batch_size": 128,
    "learning_rate": 0.002,
    "optimizer": "Adamax",
    "num_workers": 10,
    "save_name": "max_f1"
  },
  "eval": {
    "batch_size": 256,
    "num_workers": 0
  },
  "cpu_benchmark": {
    "latency_batch_size": 1,
    "throughput_batch_size": 32,
    "warmup_samples": 100,
    "measured_samples": 1000,
    "num_threads": null
  },
  "preprocess_policy": "PCAP parsed into DF DIR sequences only: ETH headers, IP addresses, TCP/UDP ports, protocol identifiers, and TLS SNI are excluded from model features. Bidirectional five-tuples are used only for flow-safe split assignment and split_manifest.tsv auditing."
}
