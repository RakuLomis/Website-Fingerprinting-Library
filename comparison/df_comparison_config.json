{
  "model": "DF",
  "datasets": ["cstnet_tls_1.3", "CipherSpectrum"],
  "raw_root": "../../TrafficData/datasets_raw_add2",
  "generated_root": "../../TrafficData/generated_for_comparison/DF",
  "results_root": "results",
  "checkpoints_root": "checkpoints",
  "python_cmd": ["conda", "run", "--no-capture-output", "-n", "Pytorch_env", "python"],
  "seed": 42,
  "split_ratios": {
    "train": 0.8,
    "val": 0.1,
    "test": 0.1
